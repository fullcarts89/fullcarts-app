  "captions": [
    { "text": "your spring cleaning haul cost *the same* this year", "fromSec": 0.0, "toSec": 2.233 },
    { "text": "but you're getting", "fromSec": 2.233, "toSec": 2.866 },
    { "text": "*less* — and I can prove it with data", "fromSec": 2.866, "toSec": 4.933 },
    { "text": "and if you're like me you did your spring cleaning in", "fromSec": 10.566, "toSec": 13.1 },
    { "text": "*June*", "fromSec": 13.233, "toSec": 14.033 },
    { "text": "number one — *Swiffer dusters*", "fromSec": 15.933, "toSec": 19.366 },
    { "text": "*28 count* — same box, same shelf, same price, now", "fromSec": 19.666, "toSec": 24.2 },
    { "text": "*24*. four dusters", "fromSec": 24.2, "toSec": 26.066 },
    { "text": "gone. a *14% cut* and they didn't say a word", "fromSec": 26.066, "toSec": 29.4 },
    { "text": "number two — *Febreze*", "fromSec": 29.4, "toSec": 30.933 },
    { "text": "used to be 8.8 ounces, now *8.1* — less than a soda's worth", "fromSec": 31.033, "toSec": 35.533 },
