# Copy to .env.local and fill in real values
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Canonical site origin — used for sitemap/robots/og:url/JSON-LD. Falls
# back to https://fullcarts.org if unset, so production works out of the
# box; local dev should set this to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=https://fullcarts.org
